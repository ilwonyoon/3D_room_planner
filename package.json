{
  "name": "pocketroom",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Mobile web 3D room planner (pocketroom) — Three.js + R3F + Claude AI",
  "scripts": {
    "dev": "vite",
    "assets:download-designconnected": "node scripts/download-designconnected-free-assets.mjs",
    "assets:download-dimensiva": "node scripts/download-dimensiva-free-assets.mjs",
    "assets:download-muuto": "node scripts/download-muuto-3d-assets.mjs",
    "assets:download-3dsky": "node scripts/download-3dsky-free-assets.mjs",
    "assets:download-vitra": "node scripts/download-vitra-glb-assets.mjs",
    "assets:download-herman-miller": "node scripts/download-herman-miller-configurator-assets.mjs",
    "assets:download-zeel": "node scripts/download-zeel-free-assets.mjs",
    "assets:update-designconnected-metadata": "node scripts/update-designconnected-metadata.mjs",
    "assets:generate-manual-catalog": "node scripts/generate-manual-product-catalog.mjs",
    "assets:fetch": "node scripts/fetch-assets.mjs",
    "assets:import-manual": "node scripts/import-manual-assets.mjs",
    "assets:install-ktx": "node scripts/install-ktx-tools.mjs",
    "assets:prepare": "node scripts/prepare-assets.mjs",
    "assets:prepare:ktx2": "pnpm assets:install-ktx && ASSET_MODEL_VARIANT=ktx2 ASSET_TEXTURE_FORMAT=ktx2 pnpm assets:prepare",
    "assets:prepare:textures:ktx2": "pnpm assets:install-ktx && ASSET_PREPARE_SCOPE=textures ASSET_TEXTURE_FORMAT=ktx2 pnpm assets:prepare",
    "assets:prepare:shell:ktx2": "pnpm assets:install-ktx && ASSET_PREPARE_SCOPE=textures ASSET_TEXTURE_FORMAT=ktx2 ASSET_TEXTURE_FILTER=walls/Plaster001,floors/WoodFloor064,rugs/polyhaven-caban-boucle-rug pnpm assets:prepare",
    "assets:thumbs": "node scripts/render-model-thumbnails.mjs",
    "assets:setup": "pnpm assets:fetch && pnpm assets:prepare && pnpm assets:thumbs",
    "assets:inspect": "node scripts/inspect-assets.mjs",
    "assets:audit-render": "node scripts/audit-render-assets.mjs",
    "assets:audit-runtime-budget": "node scripts/audit-asset-runtime-budget.mjs",
    "assets:audit-editor-bounds": "node scripts/audit-editor-model-bounds.mjs",
    "assets:audit-room-settings": "node scripts/audit-room-setting-model-bounds.mjs",
    "blender:audit-hero-assets": "node scripts/blender-audit-hero-assets.mjs",
    "blender:bake-room-lighting": "node scripts/blender-bake-room-lighting.mjs",
    "blender:bake-furniture-4k": "node scripts/blender-bake-furniture-4k-variants.mjs",
    "blender:create-hero-variants": "node scripts/blender-create-hero-variants.mjs",
    "blender:create-runtime-variants": "node scripts/blender-create-runtime-variants.mjs",
    "blender:validate-runtime-variants": "node scripts/validate-runtime-variants.mjs",
    "blender:export-static-shell": "node scripts/blender-export-static-shell.mjs",
    "blender:render-reference": "node scripts/blender-render-room-reference.mjs",
    "render:quality-metrics": "node scripts/measure-render-quality.mjs",
    "render:budget": "node scripts/measure-render-budget.mjs",
    "render:record-preference": "node scripts/record-render-preference.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "postprocessing": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fbx2gltf": "0.9.7-p1",
    "obj2gltf": "^3.2.0",
    "playwright": "^1.59.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0"
  }
}
